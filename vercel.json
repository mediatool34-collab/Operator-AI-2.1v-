{
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/meta-callback",
      "destination": "/api/meta-callback"
    },
    {
      "source": "/api/adaccounts",
      "destination": "/api/adaccounts"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://anty-ads-operator-production.up.railway.app/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
