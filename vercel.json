{
      "framework": "vite",
      "rewrites": [
              {
                        "source": "/api/auth/callback/(.*)",
                        "destination": "/api/auth/callback/$1"
              },
              {
                        "source": "/api/auth/connect/(.*)",
                        "destination": "/api/auth/connect/$1"
              },
              {
                        "source": "/api/(.*)",
                        "destination": "https://anty-ads-operator-production.up.railway.app/api/$1"
              },
              {
                        "source": "/(.*)",
                        "destination": "/index.html"
              }
      ]
}
