{
  "framework": "vite",
  "rewrites": [
    { "source": "/api/meta-callback", "destination": "/api/meta-callback" },
    { "source": "/api/adaccounts", "destination": "/api/meta-proxy" },
    { "source": "/api/campaigns", "destination": "/api/meta-proxy" },
    { "source": "/api/adsets", "destination": "/api/meta-proxy" },
    { "source": "/api/ads", "destination": "/api/meta-proxy" },
    { "source": "/api/insights", "destination": "/api/meta-proxy" },
    { "source": "/api/(.*)", "destination": "https://anty-ads-operator-production.up.railway.app/api/$1" },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
